# Backend environment — NAMES ONLY. Never commit real values (docs/security.md §5).
# In deployed environments these come from AWS Secrets Manager, not a file.
# Copy to `.env` for local development and fill in.

# --- Runtime ---
NODE_ENV=development            # development | qa | staging | production | test
PORT=3000
LOG_LEVEL=debug                 # trace | debug | info | warn | error | fatal

# --- Database (docs/database.md) ---
MONGODB_URI=mongodb://localhost:27017/todo

# --- Auth / tokens (docs/security.md §2) ---
JWT_ACCESS_SECRET=change-me-min-32-chars-long-secret-value
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# --- CORS (comma-separated allowlist; docs/security.md §4) ---
CORS_ORIGINS=http://localhost:5173

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
